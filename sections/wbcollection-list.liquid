<div class="wbcollection-list" data-section-id="{{ section.id }}">
  <div class="container">
    {% if section.settings.m_title != blank %}
      <h2 class="heading text-center"><span>{{ section.settings.m_title }}</span></h2>
    {% endif %}
    <div class="row rless d-flex justify-content-center">
      {%- for block in section.blocks -%}
        {%- assign collection = collections[block.settings.collection] -%}
        <div class="col-xl-2 col-lg-2 col-md-3 col-4 cless">
          <div class="wbcatb">
              <div class="wbcat_img">
                <a href="{{ collection.url }}">
                  {%- if collection.image != blank -%}
                    <img loading="lazy" src="{{ collection.image | img_url: '150x150', crop: 'center' }}" alt="{{ collection.title }}" class="img-fluid mx-auto" width="150" height="150" />
                  {%- else -%}
                    <img loading="lazy" src="https://dummyimage.com/150x150/f5f5f5" class="img-fluid mx-auto" width="150" height="150" />
                  {%- endif -%}
                </a>
              </div>
              <div class="catcontent">
                <a href="{{ collection.url }}">
                  <h2>{{ collection.title | default: 'Collection' }}</h2>
                </a>
              </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .wbcat_img img {
    width: 140px;
    height: 140px;
    object-fit: cover;
    border-radius: 50% !important;
    border: 2px solid #06623b;
    padding: 6px;
    transition: all 0.3s ease;
    background: #fff;
  }
  .wbcat_img img:hover {
    transform: scale(1.08);
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  }
  .wbcatb .catcontent h2 {
    font-weight: 700;
    font-size: 14px;
    margin-top: 12px;
    color: #06623b;
    letter-spacing: 0.5px;
    text-transform: capitalize;
  }
  .wbcollection-list {
    padding: 40px 0;
    background: #ffffff;
  }
  .wbcatb {
    text-align: center;
    margin-bottom: 25px;
  }
  .wbcollection-list .heading {
      margin-bottom: 30px;
  }
</style>

{% schema %}
{
  "name": "Collection List",
  "class": "spaced-section",
  "max_blocks": 15,
  "settings": [
    {
      "type": "text",
      "id": "m_title",
      "label": "Top Heading",
      "default": "Our Collections"
    }
  ],
  "blocks": [
    {
      "type": "webi_collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "category": "Collection"
    }
  ]
}
{% endschema %}
