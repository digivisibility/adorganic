<div class="wbcollection-list" data-section-id="{{ section.id }}">
  <div class="container">
    {% if section.settings.m_title != blank %}
      <h2 class="heading text-center"><span>{{ section.settings.m_title }}</span></h2>
    {% endif %}
    <div class="row rless d-flex justify-content-center flex-nowrap overflow-auto" style="padding-bottom: 10px;">
      {%- for block in section.blocks -%}
        {%- assign collection = collections[block.settings.collection] -%}
        <div class="col-xl-1 col-lg-2 col-md-3 col-4 cless" style="min-width: 160px;">
          <div class="wbcatb">
              <div class="wbcat_img">
                <a href="{{ collection.url }}">
                  {%- if collection.featured_image != blank -%}
                    <img loading="lazy" src="{{ collection.featured_image | img_url: '150x150', crop: 'center' }}" alt="{{ collection.title }}" width="150" height="150" />
                  {%- elsif collection.image != blank -%}
                    <img loading="lazy" src="{{ collection.image | img_url: '150x150', crop: 'center' }}" alt="{{ collection.title }}" width="150" height="150" />
                  {%- else -%}
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </a>
              </div>
              <div class="catcontent">
                <a href="{{ collection.url }}">
                  <h2>{{ collection.title | default: 'Collection' }}</h2>
                </a>
              </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .wbcat_img img {
    width: 90px !important;
    height: 90px !important;
    max-width: 90px !important;
    max-height: 90px !important;
    object-fit: cover !important;
    border-radius: 50% !important;
    border: 2px solid #A8C73A;
    padding: 3px;
    transition: all 0.3s ease;
    background: #fff;
    aspect-ratio: 1 / 1 !important;
    display: block;
    margin: 0 auto;
  }
  .wbcatb:hover .wbcat_img img {
    transform: scale(1.05);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
  }
  .catcontent h2 {
    font-weight: 500;
    font-size: 13px;
    margin-top: 8px;
    color: #000;
    text-transform: capitalize;
    letter-spacing: 0;
  }
  .wbcollection-list {
    padding: 15px 0;
    background: #ffffff;
  }
  @media (max-width: 767px) {
    .wbcat_img img {
      width: 70px !important;
      height: 70px !important;
      max-width: 70px !important;
      max-height: 70px !important;
    }
    .catcontent h2 {
      font-size: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "Collection List",
  "class": "spaced-section",
  "max_blocks": 15,
  "settings": [
    {
      "type": "text",
      "id": "m_title",
      "label": "Top Heading",
      "default": "Our Collections"
    }
  ],
  "blocks": [
    {
      "type": "webi_collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "category": "Collection"
    }
  ]
}
{% endschema %}
