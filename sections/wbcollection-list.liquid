{% schema %}
{
  "name": "Collection List",
  "class": "spaced-section",
  "max_blocks": 15,
  "settings": [
    {
      "type": "text",
      "id": "m_title",
      "label": "Top Heading",
      "default": "Our Collections"
    }
  ],
  "blocks": [
    {
      "type": "webi_collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "category": "Collection"
    }
  ]
}
{% endschema %}
