              {% render 'icon-hcart' %}
              <span id="Cartcount" style="position: absolute; top: -10px; right: -12px; background: #a8c73a; color: #fff; border-radius: 50%; width: 20px; height: 20px; font-size: 11px; display: flex; align-items: center; justify-content: center; font-weight: 700;">
                {{ cart.item_count }}
              </span>
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</header>
</{% if section.settings.enable_sticky_header %}sticky-header{% else %}div{% endif %}>


