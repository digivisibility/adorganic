<header class="header-main" style="background: {{ section.settings.topbg }}; border-bottom: 1px solid #eee;">
  <div class="container-fluid" style="padding: 15px 40px;">
    <div class="row align-items-center">
      
      <!-- MOBILE TOGGLE & LOGO -->
      <div class="col-lg-2 col-md-4 col-6 headlogo d-flex align-items-center">
        <button class="navbar-toggler d-lg-none" type="button" style="border: none; background: transparent; padding: 0; margin-right: 15px;">
          {% render 'icon-hamburger' %}
        </button>
        <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
          {%- if section.settings.logo != blank -%}
            {%- assign image_size = section.settings.logo_width | append: 'x' -%}
            <img src="{{ section.settings.logo | img_url: image_size }}"
                 class="header__heading-logo"
                 width="{{ section.settings.logo_width }}"
                 alt="{{ section.settings.logo.alt | default: shop.name }}">
          {%- else -%}
            <span class="h2">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>

      <!-- CENTER MENU -->
      <div class="col-lg-7 d-none d-lg-block text-center">
