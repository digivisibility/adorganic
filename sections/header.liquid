          <a href="{{ routes.search_url }}" class="header-icon" style="margin-right: 25px; display: inline-block;">
            <svg class="icon icon-search" style="width: 22px; height: 22px; fill: #06623B;"><use href="#icon-search"></use></svg>
          </a>
          <a href="{%- if customer -%}/account{%- else -%}/account/login{%- endif -%}" class="header-icon" style="margin-right: 25px; display: inline-block; color: #06623B;">
            {% render 'icon-account' %}
